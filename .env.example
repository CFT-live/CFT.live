# Example environment configuration for local development.
#
# Copy this file to `.env` at the repo root:
#   cp .env.example .env
#
# Never commit `.env`.

# =====================
# Next.js / Client config
# =====================

# Reown AppKit project id (WalletConnect/Reown)
NEXT_PUBLIC_APPKIT_PROJECT_ID=

# Arbitrum RPC endpoint (public URL used by both client reads and server actions)
SITE_INFURA_API_URL=

# Contract addresses (Arbitrum One)
NEXT_PUBLIC_LOTTO_CONTRACT_ADDRESS=
NEXT_PUBLIC_PREDICTION_MARKET_CONTRACT_ADDRESS=
NEXT_PUBLIC_ROULETTE_CONTRACT_ADDRESS=
NEXT_PUBLIC_CFT_REDEMPTION_POOL_CONTRACT_ADDRESS=

# The Graph endpoints
NEXT_PUBLIC_THE_GRAPH_API_URL=
NEXT_PUBLIC_LOTTO_THE_GRAPH_API_URL=
NEXT_PUBLIC_ROULETTE_THE_GRAPH_API_URL=

# Optional bearer token used by some Graph endpoints (if applicable)
NEXT_PUBLIC_THE_GRAPH_API_KEY=

# Optional environment hint used in client code
# (example values: prod, dev)
NEXT_ENVIRONMENT=dev

# Pyth contract override (optional; defaults are applied in code)
PYTH_CONTRACT=

# =====================
# Server-only secrets (DO NOT expose in NEXT_PUBLIC_*)
# =====================

# Bot/server wallet private key (0x-prefixed hex). Required for server actions that write to chain.
ARBITRUM_ONE_PRIVATE_KEY=

# Shared secret between advance worker and API route
ADVANCE_API_KEY=

